# Porta del server NestJS
PORT=3000

# MongoDB
MONGO_URI=mongodb://localhost:27017/virtualservice

# JWT
JWT_SECRET=cambia_questa_stringa_in_produzione
JWT_EXPIRES_IN=7d

# Google OAuth 2.0
# Ottieni le credenziali da: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=895437854648-r84q9709ko06n3bqvfoo210ml90btvcf.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxx
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# URL base del backend (usato nei link delle email)
BASE_URL=http://localhost:3000

# URL del frontend (per i redirect dopo OAuth e CORS)
FRONTEND_URL=http://localhost:4200

# SMTP (Nodemailer)
# Esempio con Gmail: abilita "App Password" in sicurezza account Google
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=virtual.service.leo@gmail.com
SMTP_PASS=app_password_generata
SMTP_FROM="VirtualService <virtual.service.leo@gmail.com>"
